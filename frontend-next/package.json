{
    "name": "frontend-next",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev": "next dev",
        "build": "next build",
        "start": "next start",
        "lint": "eslint",
        "codegen": "npx supabase gen types typescript --local > src/types/database.types.ts",
        "db:reset": "cd .. && npx supabase db reset && ./supabase/seed-storage.sh",
        "test:unit": "vitest run",
        "test:unit:watch": "vitest",
        "e2e": "npm run db:reset && npx playwright test",
        "e2e:prod": "npm run build && npm run db:reset && cross-env E2E_MODE=prod npx playwright test"
    },
    "dependencies": {
        "@hookform/resolvers": "^5.2.2",
        "@supabase/ssr": "^0.8.0",
        "@supabase/supabase-js": "^2.98.0",
        "@tanstack/react-query": "^5.90.21",
        "@tanstack/react-query-devtools": "^5.91.3",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "date-fns": "^4.1.0",
        "lucide-react": "^0.576.0",
        "next": "16.1.6",
        "next-themes": "^0.4.6",
        "radix-ui": "^1.4.3",
        "react": "19.2.3",
        "react-dom": "19.2.3",
        "react-hook-form": "^7.71.2",
        "react-intersection-observer": "^10.0.3",
        "sonner": "^2.0.7",
        "tailwind-merge": "^3.5.0",
        "zod": "^4.3.6",
        "zustand": "^5.0.11"
    },
    "devDependencies": {
        "@playwright/test": "^1.58.2",
        "@tailwindcss/postcss": "^4",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@types/node": "^20",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "@vitejs/plugin-react": "^6.0.1",
        "babel-plugin-react-compiler": "1.0.0",
        "cross-env": "^10.1.0",
        "eslint": "^9",
        "eslint-config-next": "16.1.6",
        "jsdom": "^29.0.0",
        "msw": "^2.12.13",
        "openapi-typescript": "^7.13.0",
        "shadcn": "^3.8.5",
        "supabase": "^2.77.1",
        "tailwindcss": "^4",
        "tw-animate-css": "^1.4.0",
        "typescript": "^5",
        "vitest": "^4.1.0"
    }
}
